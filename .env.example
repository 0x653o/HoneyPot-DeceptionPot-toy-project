# ============================================
# Honeypot Extenal Deployment Configuration
# ============================================

# The API key required to view the management dashboard.
# Change this to a strong secret before deploying.
HONEYPOT_API_KEY=hk_live_8f92bd8c734a6eef9012

# Port bindings on the host computer.
# If these ports conflict with services running on your machine,
# simply change them here and run `make run` again.
PORT_SSH=10001
PORT_HTTP=10002
PORT_FTP=10003
PORT_TELNET=10004
PORT_SMTP=10005

# Management API port (bound to localhost by default)
PORT_MGMT=9090
